% Generated by hand during the ducksemantics pivot.
\name{ducksemantics_projection_sql}
\alias{ducksemantics_projection_sql}
\title{Project any edge-shaped source relation into graph shape}
\usage{
ducksemantics_projection_sql(
  source_table,
  from,
  predicate,
  to,
  target_table = "semantic_edges",
  attrs = NULL,
  trust = NULL
)
}
\arguments{
\item{source_table}{Source table or view name.}

\item{from, predicate, to}{Source column names.}

\item{target_table}{Target table name.}

\item{attrs, trust}{Optional source columns containing JSON text.}
}
\value{
A single \code{CREATE OR REPLACE TABLE ... AS SELECT ...} SQL statement.
}
\description{
Mirrors the graph projection profile used in pi-bio-agent: a source table with
caller-named columns becomes a stable graph edge table with \code{from_id},
\code{predicate}, \code{to_id}, \code{attrs}, and \code{trust}.
}
